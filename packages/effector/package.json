  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:ecosystem": "vitest run --config vitest.ecosystem.config.mjs",
    "test:upstream": "vitest run --config vitest.upstream.config.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@virentia/core": "workspace:*"
  },
  "devDependencies": {
    "@argon-router/core": "^0.12.0",
    "@argon-router/paths": "^0.12.0",
    "@argon-router/react": "^0.12.0",
    "@effector-kit/models": "^0.4.0",
    "@effector-kit/react": "^0.4.0",
