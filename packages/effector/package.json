  "repository": {
    "type": "git",
    "url": "git+https://github.com/movpushmov/virentia.git",
    "directory": "packages/effector"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
