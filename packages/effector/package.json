    "history": "^5.3.0",
    "jsdom": "^29.1.1",
    "patronum": "^2.3.0",
    "query-string": "^9.3.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.4.3"
  }
