    "@effector-reform/react": "^0.17.0",
    "@farfetched/core": "^0.15.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@withease/contracts": "^1.1.0",
    "effector-action": "^1.2.2",
    "effector-react": "^23.3.0",
