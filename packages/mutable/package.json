{
  "name": "@virentia/mutable",
  "version": "0.1.5",
  "description": "Deep-mutable (immer-style) updates for @virentia/core stores, powered by mutative",
  "keywords": [
    "virentia",
    "immer",
    "mutative",
    "immutable",
    "state"
  ],
  "homepage": "https://movpushmov.dev/virentia/mutable/",
  "bugs": {
    "url": "https://github.com/virentia-labs/virentia/issues"
  },
  "license": "MIT",
  "author": "movpushmov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virentia-labs/virentia.git",
    "directory": "packages/mutable"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run && vitest typecheck --run --passWithNoTests",
    "test:watch": "vitest",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "@virentia/core": "workspace:*"
  },
  "devDependencies": {
    "immer": "^10.0.0",
    "mutative": "^1.3.0"
  }
}
