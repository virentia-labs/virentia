{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@virentia/core": ["packages/core/lib/index.ts"],
      "@virentia/core/devtools": ["packages/core/lib/devtools.ts"],
      "@virentia/effector": ["packages/effector/lib/index.ts"],
      "@virentia/inspector": ["packages/inspector/lib/index.ts"],
      "@virentia/inspector/effector": ["packages/inspector/lib/effector/index.ts"],
      "@virentia/react": ["packages/react/lib/index.ts"],
      "@virentia/vue": ["packages/vue/lib/index.ts"]
    }
  },
  "include": [
    "packages/core/lib/**/*.ts",
    "packages/core/tests/**/*.ts",
    "packages/core/tsdown.config.ts",
    "packages/effector/lib/**/*.ts",
    "packages/effector/tests/**/*.ts",
    "packages/effector/tsdown.config.ts",
    "packages/inspector/lib/**/*.ts",
    "packages/inspector/lib/**/*.tsx",
    "packages/inspector/tests/**/*.ts",
    "packages/inspector/tsdown.config.ts",
    "packages/inspector/vite.config.ts",
    "packages/react/lib/**/*.ts",
    "packages/react/tests/**/*.ts",
    "packages/react/tsdown.config.ts",
    "packages/vue/lib/**/*.ts",
    "packages/vue/tests/**/*.ts",
    "packages/vue/tsdown.config.ts"
  ]
}
